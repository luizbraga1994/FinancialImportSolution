{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/api-log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithEnvironmentName" ]
  },

  "ConnectionStrings": {
    "DefaultConnection": ""
  },

  "HanaDbConnection": {
    "Server": "",
    "Port": "30015",
    "Database": "SBOCOMMON",
    "UserID": "",
    "Password": "",
    "MaxPoolSize": 100,
    "MinPoolSize": 10,
    "ConnectionTimeout": 60,
    "CommandTimeout": 300,
    "ProviderInvariantName": "Sap.Data.Hana",
    "ProviderAssemblyPath": ""
  },

  "AdminSeed": {
    "Login": "",
    "Password": "",
    "Email": "",
    "Name": ""
  }
}
