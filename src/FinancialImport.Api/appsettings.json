{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/api-log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithEnvironmentName" ]
  },

  "ConnectionStrings": {
    "DefaultConnection": ""
  },

  "Jwt": {
    "SecretKey": "",
    "Issuer": "FinancialImport",
    "Audience": "FinancialImportClients",
    "ExpirationMinutes": 480,
    "RefreshExpirationMinutes": 1440,
    "ClockSkewMinutes": 1
  },

  "Cors": {
    "AllowedOrigins": [ "https://localhost:7000", "http://localhost:5000" ]
  },

  "HanaDbConnection": {
    "Server": "",
    "Port": "30015",
    "Database": "SBOCOMMON",
    "UserID": "",
    "Password": "",
    "MaxPoolSize": 100,
    "MinPoolSize": 10,
    "ConnectionTimeout": 60,
    "CommandTimeout": 300,
    "ProviderInvariantName": "Sap.Data.Hana",
    "ProviderAssemblyPath": ""
  },

  "SapServiceLayer": {
    "BaseUrl": "",
    "UserName": "",
    "Password": "",
    "Language": 29,
    "IgnoreSslErrors": false,
    "TimeoutSeconds": 180,
    "MaxRetryAttempts": 3,
    "SessionTimeoutMinutes": 25
  },

  "LayoutParsing": {
    "DefaultTipoLancLayout1": "D"
  },

  "AdminSeed": {
    "Login": "",
    "Password": "",
    "Email": "",
    "Name": ""
  },

  "Imports": {
    "Processing": {
      "MaxFileSizeBytes": 10485760,
      "AllowedExtensions": [ ".csv", ".txt", ".xlsx" ],
      "BatchSizeLines": 500,
      "MaxDegreeOfParallelism": 1,
      "MemoMaxLength": 254,
      "ReferenceMaxLength": 27,
      "LineMemoMaxLength": 50,
      "JournalBalanceTolerance": 0.01,
      "PostingDateFutureToleranceDays": 1,
      "DeduplicationKey": {
        "IncludeCompanyDb": true,
        "IncludeReference": true,
        "IncludeAccounts": true,
        "IncludeDates": true,
        "IncludeAmount": true,
        "IncludeMemo": true,
        "IncludeBranch": true,
        "IncludeSeqLancamento": true
      }
    }
  },

  "Messaging": {
    "RabbitMq": {
      "Enabled": false,
      "HostName": "localhost",
      "Port": 5672,
      "VirtualHost": "/",
      "UserName": "",
      "Password": "",
      "ExchangeName": "financialimport.exchange",
      "DeadLetterExchangeName": "financialimport.dlx",
      "PrefetchCount": 16,
      "MaxRetryAttempts": 5,
      "InitialRetryDelaySeconds": 2,
      "RetryBackoffMultiplier": 2,
      "MaxRetryDelaySeconds": 300,
      "ConnectionRecoveryIntervalSeconds": 10,
      "NetworkRecoveryIntervalSeconds": 10,
      "UseSsl": false,
      "Channels": {
        "import.process.command": {
          "Queue": "financialimport.import.process",
          "RoutingKey": "import.process",
          "Durable": true
        },
        "import.reprocess.command": {
          "Queue": "financialimport.import.reprocess",
          "RoutingKey": "import.reprocess",
          "Durable": true
        },
        "sap.dispatch.command": {
          "Queue": "financialimport.sap.dispatch",
          "RoutingKey": "sap.dispatch",
          "Durable": true
        },
        "audit.write.command": {
          "Queue": "financialimport.audit.write",
          "RoutingKey": "audit.write",
          "Durable": true
        }
      }
    },
    "Kafka": {
      "Enabled": false,
      "BootstrapServers": "localhost:9092",
      "ClientId": "financialimport-api",
      "ConsumerGroupId": "financialimport-api",
      "LingerMs": 20,
      "BatchSize": 32768,
      "MaxInFlightRequests": 5,
      "EnableIdempotence": true,
      "Acks": "all",
      "Topics": {
        "import.events": { "Topic": "financialimport.import.events", "Partitions": 3, "ReplicationFactor": 1 },
        "sap.events":    { "Topic": "financialimport.sap.events",    "Partitions": 3, "ReplicationFactor": 1 },
        "security.events": { "Topic": "financialimport.security.events", "Partitions": 3, "ReplicationFactor": 1 },
        "audit.events":  { "Topic": "financialimport.audit.events",  "Partitions": 3, "ReplicationFactor": 1 }
      }
    },
    "Outbox": {
      "Enabled": true,
      "PollingIntervalSeconds": 5,
      "BatchSize": 100,
      "MaxAttempts": 10,
      "ClaimTimeoutSeconds": 120
    }
  }
}
