{
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.txt",
          "rollingInterval": "Day"
        }
      }
    ]
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=FinancialImport;User=root;Password=#7reGT#15OyUUa!;Port=3306;"
  },
  "Jwt": {
    "SecretKey": "CHANGE_ME_USE_A_STRONG_SECRET_KEY_WITH_AT_LEAST_32_CHARS",
    "Issuer": "FinancialImport",
    "Audience": "FinancialImportClients",
    "ExpirationMinutes": 480,
    "RefreshExpirationMinutes": 1440
  },
  "HanaDbConnection": {
    "Server": "saphaalbieri:30015",
    "Port": "30015",
    "Database": "SBOCOMMON",
    "UserID": "SYSTEM",
    "Password": "#7reGT#15OyUUa!",
    "MaxPoolSize": 100,
    "MinPoolSize": 10,
    "ConnectionTimeout": 60,
    "CommandTimeout": 300
  },
  "SapServiceLayer": {
    "BaseUrl": "https://sap-albieri-sl.skyinone.net:50000",
    "TimeoutSeconds": 100,
    "MaxRetries": 3,
    "SessionDurationMinutes": 30
  },
  "LayoutParsing": {
    "DefaultTipoLancLayout1": "D"
  },
  "AdminSeed": {
    "Login": "admin",
    "Password": "Admin@123",
    "Email": "admin@financialimport.local",
    "Name": "Administrador Global"
  },
  "Security": {
    "Cookie": { "ExpirationHours": 8 }
  },
  "Imports": {
    "Processing": {
      "MaxFileSizeBytes": 10485760,
      "AllowedExtensions": [ ".csv", ".txt", ".xlsx" ],
      "BatchSizeLines": 500,
      "MaxDegreeOfParallelism": 1,
      "MemoMaxLength": 254,
      "ReferenceMaxLength": 27,
      "LineMemoMaxLength": 50,
      "JournalBalanceTolerance": 0.01,
      "PostingDateFutureToleranceDays": 1,
      "DeduplicationKey": {
        "IncludeCompanyDb": true,
        "IncludeReference": true,
        "IncludeAccounts": true,
        "IncludeDates": true,
        "IncludeAmount": true,
        "IncludeMemo": true,
        "IncludeBranch": true,
        "IncludeSeqLancamento": true
      }
    }
  },
  "Messaging": {
    "RabbitMq": {
      "Enabled": false,
      "HostName": "localhost",
      "Port": 5672,
      "VirtualHost": "/",
      "UserName": "guest",
      "Password": "guest",
      "ExchangeName": "financialimport.exchange",
      "DeadLetterExchangeName": "financialimport.dlx",
      "Channels": {
        "import.process.command": { "Queue": "financialimport.import.process", "RoutingKey": "import.process", "Durable": true },
        "sap.dispatch.command":    { "Queue": "financialimport.sap.dispatch",    "RoutingKey": "sap.dispatch",    "Durable": true }
      }
    },
    "Kafka": {
      "Enabled": false,
      "BootstrapServers": "localhost:9092",
      "ClientId": "financialimport-web-dev",
      "ConsumerGroupId": "financialimport-web-dev",
      "Topics": {
        "import.events": { "Topic": "financialimport.import.events.dev", "Partitions": 1, "ReplicationFactor": 1 },
        "sap.events":    { "Topic": "financialimport.sap.events.dev",    "Partitions": 1, "ReplicationFactor": 1 },
        "audit.events":  { "Topic": "financialimport.audit.events.dev",  "Partitions": 1, "ReplicationFactor": 1 },
        "security.events": { "Topic": "financialimport.security.events.dev", "Partitions": 1, "ReplicationFactor": 1 }
      }
    },
    "Outbox": {
      "Enabled": true,
      "PollingIntervalSeconds": 5,
      "BatchSize": 100,
      "MaxAttempts": 10,
      "ClaimTimeoutSeconds": 120
    }
  }
}
