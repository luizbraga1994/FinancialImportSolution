@model IReadOnlyCollection<FinancialImport.Application.Models.SapCompanyInfo>
@{
    ViewData["Title"] = "Selecionar Empresa";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Selecionar Empresa</h1>
</div>

<div asp-validation-summary="All" class="text-danger small mb-3"></div>

@if (Model == null || Model.Count == 0)
{
    <div class="text-center text-muted py-5">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" class="d-block mx-auto mb-3 opacity-25" viewBox="0 0 16 16">
            <path d="M4 2.5a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-1a.5.5 0 0 1-.5-.5zm3 0a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-1a.5.5 0 0 1-.5-.5zm3.5-.5a.5.5 0 0 0-.5.5v1a.5.5 0 0 0 .5.5h1a.5.5 0 0 0 .5-.5v-1a.5.5 0 0 0-.5-.5zM4 5.5a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-1a.5.5 0 0 1-.5-.5zM7.5 5a.5.5 0 0 0-.5.5v1a.5.5 0 0 0 .5.5h1a.5.5 0 0 0 .5-.5v-1a.5.5 0 0 0-.5-.5zm2.5.5a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-1a.5.5 0 0 1-.5-.5zM4.5 8a.5.5 0 0 0-.5.5v1a.5.5 0 0 0 .5.5h1a.5.5 0 0 0 .5-.5v-1a.5.5 0 0 0-.5-.5zm2.5.5a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-1a.5.5 0 0 1-.5-.5zm3.5-.5a.5.5 0 0 0-.5.5v1a.5.5 0 0 0 .5.5h1a.5.5 0 0 0 .5-.5v-1a.5.5 0 0 0-.5-.5z"/>
            <path d="M2 1a1 1 0 0 1 1-1h10a1 1 0 0 1 1 1v14a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1zm11 0H3v14h3v-2.5a.5.5 0 0 1 .5-.5h3a.5.5 0 0 1 .5.5V15h3z"/>
        </svg>
        <p>Nenhuma empresa disponivel.</p>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var company in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 @(company.IsActive ? "" : "border-secondary opacity-75")">
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex align-items-start mb-3">
                            <div class="bg-dark text-white rounded d-inline-flex align-items-center justify-content-center me-3 flex-shrink-0"
                                 style="width: 48px; height: 48px;">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M4 2.5a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-1a.5.5 0 0 1-.5-.5zm3 0a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-1a.5.5 0 0 1-.5-.5zm3.5-.5a.5.5 0 0 0-.5.5v1a.5.5 0 0 0 .5.5h1a.5.5 0 0 0 .5-.5v-1a.5.5 0 0 0-.5-.5zM4 5.5a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-1a.5.5 0 0 1-.5-.5zM7.5 5a.5.5 0 0 0-.5.5v1a.5.5 0 0 0 .5.5h1a.5.5 0 0 0 .5-.5v-1a.5.5 0 0 0-.5-.5zm2.5.5a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-1a.5.5 0 0 1-.5-.5zM4.5 8a.5.5 0 0 0-.5.5v1a.5.5 0 0 0 .5.5h1a.5.5 0 0 0 .5-.5v-1a.5.5 0 0 0-.5-.5zm2.5.5a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-1a.5.5 0 0 1-.5-.5zm3.5-.5a.5.5 0 0 0-.5.5v1a.5.5 0 0 0 .5.5h1a.5.5 0 0 0 .5-.5v-1a.5.5 0 0 0-.5-.5z"/>
                                    <path d="M2 1a1 1 0 0 1 1-1h10a1 1 0 0 1 1 1v14a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1zm11 0H3v14h3v-2.5a.5.5 0 0 1 .5-.5h3a.5.5 0 0 1 .5.5V15h3z"/>
                                </svg>
                            </div>
                            <div>
                                <h5 class="card-title mb-1">@company.CompanyName</h5>
                                <p class="text-muted small mb-0">
                                    <code>@company.CompanyDb</code>
                                </p>
                                @if (!string.IsNullOrEmpty(company.Server))
                                {
                                    <p class="text-muted small mb-0">Servidor: @company.Server</p>
                                }
                            </div>
                        </div>
                        <div class="mt-auto">
                            @if (company.IsActive)
                            {
                                <form asp-controller="Company" asp-action="Select" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="companyDb" value="@company.CompanyDb" />

                                    <div class="mb-2">
                                        <input type="text"
                                               class="form-control form-control-sm"
                                               name="sapUser"
                                               placeholder="Usuario SAP"
                                               required />
                                    </div>
                                    <div class="mb-3">
                                        <input type="password"
                                               class="form-control form-control-sm"
                                               name="sapPassword"
                                               placeholder="Senha SAP"
                                               required />
                                    </div>

                                    <button type="submit" class="btn btn-primary btn-sm w-100">
                                        Conectar
                                    </button>
                                </form>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inativa</span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
