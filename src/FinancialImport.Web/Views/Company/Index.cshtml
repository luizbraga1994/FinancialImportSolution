@model IReadOnlyCollection<FinancialImport.Application.Models.SapCompanyInfo>
@{
    ViewData["Title"] = "Selecionar Empresa";
}

<div class="mb-4">
    <h5 class="fw-bold mb-1">Selecionar Empresa</h5>
    <p class="text-muted mb-0" style="font-size: 0.85rem;">Clique na empresa desejada para conectar</p>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        <div>@TempData["Error"]</div>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div asp-validation-summary="All" class="text-danger small mb-3"></div>

@if (Model == null || Model.Count == 0)
{
    <div class="card">
        <div class="card-body">
            <div class="empty-state py-5">
                <div class="empty-state-icon">
                    <i class="bi bi-building"></i>
                </div>
                <h6 class="empty-state-title">Nenhuma empresa disponivel</h6>
                <p class="empty-state-text">Nao foi possivel carregar as empresas do HANA</p>
            </div>
        </div>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var company in Model.Where(c => c.IsActive))
        {
            <div class="col-md-6 col-lg-4 col-xl-3">
                <form asp-controller="Company" asp-action="Select" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="companyDb" value="@company.CompanyDb" />
                    <button type="submit" class="company-card card h-100 w-100 border-0 text-start">
                        <div class="card-body p-3">
                            <div class="d-flex align-items-center gap-3">
                                <div class="company-icon">
                                    <i class="bi bi-building"></i>
                                </div>
                                <div class="flex-grow-1 overflow-hidden">
                                    <div class="fw-semibold text-truncate" style="font-size: 0.875rem;">@company.CompanyName</div>
                                    <code class="text-muted" style="font-size: 0.75rem;">@company.CompanyDb</code>
                                </div>
                                <i class="bi bi-chevron-right text-muted"></i>
                            </div>
                        </div>
                    </button>
                </form>
            </div>
        }
    </div>

    @{
        var inactiveCompanies = Model.Where(c => !c.IsActive).ToList();
    }
    @if (inactiveCompanies.Any())
    {
        <div class="mt-4">
            <div class="sidebar-section-title mb-2" style="color: #94a3b8; font-size: 0.7rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em;">
                Empresas Inativas
            </div>
            <div class="row g-3">
                @foreach (var company in inactiveCompanies)
                {
                    <div class="col-md-6 col-lg-4 col-xl-3">
                        <div class="card h-100 border-0 opacity-50">
                            <div class="card-body p-3">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="company-icon company-icon-inactive">
                                        <i class="bi bi-building"></i>
                                    </div>
                                    <div class="flex-grow-1 overflow-hidden">
                                        <div class="fw-semibold text-truncate" style="font-size: 0.875rem;">@company.CompanyName</div>
                                        <code class="text-muted" style="font-size: 0.75rem;">@company.CompanyDb</code>
                                    </div>
                                    <span class="badge bg-secondary-subtle text-secondary-emphasis" style="font-size: 0.65rem;">Inativa</span>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
}

<style>
    .company-card {
        cursor: pointer;
        transition: all 0.2s ease;
        background: #fff;
        border: 1.5px solid #e8ecf1 !important;
    }
    .company-card:hover {
        border-color: #3b82f6 !important;
        background: #f8fafc;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(59, 130, 246, 0.12);
    }
    .company-card:hover .company-icon {
        background: #3b82f6;
        color: #fff;
    }
    .company-card:hover .bi-chevron-right {
        color: #3b82f6 !important;
        transform: translateX(2px);
    }
    .company-icon {
        width: 42px;
        height: 42px;
        border-radius: 10px;
        background: #f1f5f9;
        color: #475569;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        flex-shrink: 0;
        transition: all 0.2s ease;
    }
    .company-icon-inactive {
        background: #f1f5f9;
        color: #94a3b8;
    }
    .bi-chevron-right {
        transition: all 0.2s ease;
    }
</style>
