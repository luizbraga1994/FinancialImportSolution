@using Microsoft.AspNetCore.Mvc.Rendering
@model FinancialImport.Web.Models.CompanySelectionViewModel
@{
    ViewData["Title"] = "Selecionar Company";
}

<h2>Selecionar base SAP</h2>

<form asp-action="Select" method="post">
    <div class="mb-3">
        <label asp-for="CompanyDb" class="form-label">Company</label>
        <select asp-for="CompanyDb" class="form-select" asp-items="@(new SelectList(Model.Companies, "CompanyDb", "CompanyName"))">
            <option value="">Selecione</option>
        </select>
        <span asp-validation-for="CompanyDb" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="SapUserName" class="form-label">Usuário SAP</label>
        <input asp-for="SapUserName" class="form-control" />
        <span asp-validation-for="SapUserName" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="SapPassword" class="form-label">Senha SAP</label>
        <input asp-for="SapPassword" class="form-control" />
        <span asp-validation-for="SapPassword" class="text-danger"></span>
    </div>
    @if (!string.IsNullOrWhiteSpace(Model.Error))
    {
        <div class="alert alert-danger">@Model.Error</div>
    }
    <button type="submit" class="btn btn-primary">Entrar na base</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
