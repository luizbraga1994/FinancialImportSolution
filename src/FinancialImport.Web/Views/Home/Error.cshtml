@{
    ViewData["Title"] = "Erro";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6 text-center">
        <div class="mb-4">
            <i class="bi bi-exclamation-circle text-danger" style="font-size: 4rem;"></i>
        </div>
        <h2 class="fw-bold">Ocorreu um Erro</h2>
        <p class="text-muted mb-4">
            Algo inesperado aconteceu ao processar sua solicitacao.
            Por favor, tente novamente mais tarde ou entre em contato com o administrador.
        </p>
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary px-4">
            <i class="bi bi-arrow-left me-2"></i>Voltar para o Inicio
        </a>
    </div>
</div>
