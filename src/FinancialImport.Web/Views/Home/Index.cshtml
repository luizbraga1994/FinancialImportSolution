@{
    ViewData["Title"] = "Dashboard";
}

<!-- Stats Row -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card border-0">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="stat-icon bg-primary-subtle text-primary">
                        <i class="bi bi-file-earmark-check"></i>
                    </div>
                    <div class="ms-3">
                        <div class="stat-value">0</div>
                        <div class="stat-label">Importacoes Realizadas</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card border-0">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="stat-icon bg-warning-subtle text-warning">
                        <i class="bi bi-hourglass-split"></i>
                    </div>
                    <div class="ms-3">
                        <div class="stat-value">0</div>
                        <div class="stat-label">Pendentes</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card border-0">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="stat-icon bg-danger-subtle text-danger">
                        <i class="bi bi-exclamation-triangle"></i>
                    </div>
                    <div class="ms-3">
                        <div class="stat-value">0</div>
                        <div class="stat-label">Com Erro</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card border-0">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="stat-icon bg-success-subtle text-success">
                        <i class="bi bi-check-circle"></i>
                    </div>
                    <div class="ms-3">
                        <div class="stat-value">0</div>
                        <div class="stat-label">Enviados ao SAP</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Quick Actions + Recent Activity -->
<div class="row g-3">
    <div class="col-lg-4">
        <div class="card border-0 h-100">
            <div class="card-header bg-transparent border-0 pt-3">
                <h6 class="fw-bold mb-0"><i class="bi bi-lightning-charge me-2"></i>Acoes Rapidas</h6>
            </div>
            <div class="card-body d-grid gap-2">
                <a asp-controller="Import" asp-action="Index" class="btn btn-primary">
                    <i class="bi bi-upload me-2"></i>Nova Importacao
                </a>
                <a asp-controller="History" asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-clock-history me-2"></i>Ver Historico
                </a>
                <a asp-controller="Company" asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-building me-2"></i>Trocar Empresa
                </a>
            </div>
        </div>
    </div>
    <div class="col-lg-8">
        <div class="card border-0 h-100">
            <div class="card-header bg-transparent border-0 pt-3 d-flex justify-content-between align-items-center">
                <h6 class="fw-bold mb-0"><i class="bi bi-activity me-2"></i>Atividade Recente</h6>
                <a asp-controller="History" asp-action="Index" class="btn btn-sm btn-link text-decoration-none">Ver tudo</a>
            </div>
            <div class="card-body">
                <div class="text-center text-muted py-4">
                    <i class="bi bi-inbox" style="font-size: 2.5rem; opacity: 0.3;"></i>
                    <p class="mt-2 mb-0">Nenhuma atividade recente</p>
                    <p class="small">As importacoes realizadas aparecerao aqui</p>
                </div>
            </div>
        </div>
    </div>
</div>
