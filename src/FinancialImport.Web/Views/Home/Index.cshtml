@{
    ViewData["Title"] = "Dashboard";
}

<!-- Stats Row -->
<div class="row g-4 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card">
            <div class="card-body p-4">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <div class="stat-icon stat-icon-blue">
                        <i class="bi bi-file-earmark-check"></i>
                    </div>
                    <span class="stat-badge stat-badge-blue">Total</span>
                </div>
                <div class="stat-value">0</div>
                <div class="stat-label">Importacoes Realizadas</div>
                <div class="stat-trend mt-2">
                    <i class="bi bi-graph-up-arrow"></i>
                    <span>Nenhuma importacao ainda</span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card">
            <div class="card-body p-4">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <div class="stat-icon stat-icon-amber">
                        <i class="bi bi-hourglass-split"></i>
                    </div>
                    <span class="stat-badge stat-badge-amber">Aguardando</span>
                </div>
                <div class="stat-value">0</div>
                <div class="stat-label">Pendentes</div>
                <div class="stat-trend mt-2">
                    <i class="bi bi-dash"></i>
                    <span>Sem pendencias</span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card">
            <div class="card-body p-4">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <div class="stat-icon stat-icon-red">
                        <i class="bi bi-exclamation-triangle"></i>
                    </div>
                    <span class="stat-badge stat-badge-red">Atencao</span>
                </div>
                <div class="stat-value">0</div>
                <div class="stat-label">Com Erro</div>
                <div class="stat-trend mt-2">
                    <i class="bi bi-check-lg"></i>
                    <span>Nenhum erro encontrado</span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card">
            <div class="card-body p-4">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <div class="stat-icon stat-icon-green">
                        <i class="bi bi-check-circle"></i>
                    </div>
                    <span class="stat-badge stat-badge-green">SAP B1</span>
                </div>
                <div class="stat-value">0</div>
                <div class="stat-label">Enviados ao SAP</div>
                <div class="stat-trend mt-2">
                    <i class="bi bi-arrow-right"></i>
                    <span>Pronto para importar</span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Quick Actions + Recent Activity -->
<div class="row g-4">
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-body p-4">
                <div class="d-flex align-items-center mb-4">
                    <div class="section-icon">
                        <i class="bi bi-lightning-charge-fill"></i>
                    </div>
                    <h6 class="fw-bold mb-0 ms-3">Acoes Rapidas</h6>
                </div>

                <div class="d-grid gap-3">
                    <a asp-controller="Import" asp-action="Index" class="action-card action-card-primary">
                        <div class="action-card-icon">
                            <i class="bi bi-cloud-upload"></i>
                        </div>
                        <div>
                            <div class="action-card-title">Nova Importacao</div>
                            <div class="action-card-desc">Importar arquivo contabil</div>
                        </div>
                        <i class="bi bi-chevron-right ms-auto"></i>
                    </a>

                    <a asp-controller="History" asp-action="Index" class="action-card">
                        <div class="action-card-icon action-card-icon-secondary">
                            <i class="bi bi-clock-history"></i>
                        </div>
                        <div>
                            <div class="action-card-title">Ver Historico</div>
                            <div class="action-card-desc">Importacoes anteriores</div>
                        </div>
                        <i class="bi bi-chevron-right ms-auto"></i>
                    </a>

                    <a asp-controller="Company" asp-action="Index" class="action-card">
                        <div class="action-card-icon action-card-icon-secondary">
                            <i class="bi bi-building"></i>
                        </div>
                        <div>
                            <div class="action-card-title">Trocar Empresa</div>
                            <div class="action-card-desc">Selecionar outra company</div>
                        </div>
                        <i class="bi bi-chevron-right ms-auto"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card h-100">
            <div class="card-body p-4">
                <div class="d-flex align-items-center justify-content-between mb-4">
                    <div class="d-flex align-items-center">
                        <div class="section-icon section-icon-purple">
                            <i class="bi bi-activity"></i>
                        </div>
                        <h6 class="fw-bold mb-0 ms-3">Atividade Recente</h6>
                    </div>
                    <a asp-controller="History" asp-action="Index" class="btn btn-sm btn-light fw-medium">
                        Ver tudo <i class="bi bi-arrow-right ms-1"></i>
                    </a>
                </div>

                <div class="empty-state">
                    <div class="empty-state-icon">
                        <i class="bi bi-inbox"></i>
                    </div>
                    <h6 class="empty-state-title">Nenhuma atividade recente</h6>
                    <p class="empty-state-text">As importacoes realizadas aparecerao aqui com status em tempo real</p>
                    <a asp-controller="Import" asp-action="Index" class="btn btn-sm btn-primary mt-2">
                        <i class="bi bi-upload me-1"></i> Fazer primeira importacao
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
