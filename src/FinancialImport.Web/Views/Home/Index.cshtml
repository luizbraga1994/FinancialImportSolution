@using FinancialImport.Infrastructure.Data
@using Microsoft.EntityFrameworkCore
@inject AppDbContext DbContext
@inject FinancialImport.Application.Abstractions.ICompanyContext CompanyContext
@{
    ViewData["Title"] = "Dashboard";
    
    var companyDb = CompanyContext.CompanyDb;
    var imports = new List<FinancialImport.Domain.Entities.ImportFile>();
    var totalImported = 0;
    var totalPending = 0;
    var totalErrors = 0;
    var totalSent = 0;
    
    if (!string.IsNullOrWhiteSpace(companyDb))
    {
        imports = await DbContext.ImportFiles
            .Where(i => i.CompanyDb == companyDb)
            .OrderByDescending(i => i.ImportedAt)
            .Take(10)
            .ToListAsync();
            
        totalImported = imports.Count;
        totalPending = imports.Count(i => i.Status == FinancialImport.Domain.Enums.ImportStatus.Pending || i.Status == FinancialImport.Domain.Enums.ImportStatus.Validated);
        totalErrors = imports.Sum(i => i.LinesWithError);
        totalSent = imports.Sum(i => i.ImportedLines);
    }
}

<div class="row g-4 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card">
            <div class="card-body p-4">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <div class="stat-icon stat-icon-blue">
                        <i class="bi bi-file-earmark-check"></i>
                    </div>
                    <span class="stat-badge stat-badge-blue">Total</span>
                </div>
                <div class="stat-value">@totalImported</div>
                <div class="stat-label">Importacoes Realizadas</div>
                <div class="stat-trend mt-2">
                    <i class="bi bi-graph-up-arrow"></i>
                    <span>@(totalImported > 0 ? $"{totalImported} importaçõe(s)" : "Nenhuma importação ainda")</span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card">
            <div class="card-body p-4">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <div class="stat-icon stat-icon-amber">
                        <i class="bi bi-hourglass-split"></i>
                    </div>
                    <span class="stat-badge stat-badge-amber">Aguardando</span>
                </div>
                <div class="stat-value">@totalPending</div>
                <div class="stat-label">Pendentes</div>
                <div class="stat-trend mt-2">
                    <i class="bi bi-dash"></i>
                    <span>@(totalPending > 0 ? $"{totalPending} pendente(s)" : "Sem pendências")</span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card">
            <div class="card-body p-4">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <div class="stat-icon stat-icon-red">
                        <i class="bi bi-exclamation-triangle"></i>
                    </div>
                    <span class="stat-badge stat-badge-red">Atencao</span>
                </div>
                <div class="stat-value">@totalErrors</div>
                <div class="stat-label">Com Erro</div>
                <div class="stat-trend mt-2">
                    <i class="bi bi-check-lg"></i>
                    <span>@(totalErrors > 0 ? $"{totalErrors} erro(s)" : "Nenhum erro encontrado")</span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card">
            <div class="card-body p-4">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <div class="stat-icon stat-icon-green">
                        <i class="bi bi-check-circle"></i>
                    </div>
                    <span class="stat-badge stat-badge-green">SAP B1</span>
                </div>
                <div class="stat-value">@totalSent</div>
                <div class="stat-label">Enviados ao SAP</div>
                <div class="stat-trend mt-2">
                    <i class="bi bi-arrow-right"></i>
                    <span>@(totalSent > 0 ? $"{totalSent} lançamento(s)" : "Pronto para importar")</span>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-body p-4">
                <div class="d-flex align-items-center mb-4">
                    <div class="section-icon">
                        <i class="bi bi-lightning-charge-fill"></i>
                    </div>
                    <h6 class="fw-bold mb-0 ms-3">Acoes Rapidas</h6>
                </div>

                <div class="d-grid gap-3">
                    <a asp-controller="Import" asp-action="Index" class="action-card action-card-primary" data-loading data-loading-message="Carregando importação...">
                        <div class="action-card-icon">
                            <i class="bi bi-cloud-upload"></i>
                        </div>
                        <div>
                            <div class="action-card-title">Nova Importacao</div>
                            <div class="action-card-desc">Importar arquivo contabil</div>
                        </div>
                        <i class="bi bi-chevron-right ms-auto"></i>
                    </a>

                    <a asp-controller="History" asp-action="Index" class="action-card" data-loading data-loading-message="Carregando histórico...">
                        <div class="action-card-icon action-card-icon-secondary">
                            <i class="bi bi-clock-history"></i>
                        </div>
                        <div>
                            <div class="action-card-title">Ver Historico</div>
                            <div class="action-card-desc">Importacoes anteriores</div>
                        </div>
                        <i class="bi bi-chevron-right ms-auto"></i>
                    </a>

                    <a asp-controller="Company" asp-action="Index" class="action-card" data-loading data-loading-message="Carregando empresas...">
                        <div class="action-card-icon action-card-icon-secondary">
                            <i class="bi bi-building"></i>
                        </div>
                        <div>
                            <div class="action-card-title">Trocar Empresa</div>
                            <div class="action-card-desc">Selecionar outra company</div>
                        </div>
                        <i class="bi bi-chevron-right ms-auto"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card h-100">
            <div class="card-body p-4">
                <div class="d-flex align-items-center justify-content-between mb-4">
                    <div class="d-flex align-items-center">
                        <div class="section-icon section-icon-purple">
                            <i class="bi bi-activity"></i>
                        </div>
                        <h6 class="fw-bold mb-0 ms-3">Atividade Recente</h6>
                    </div>
                    <a asp-controller="History" asp-action="Index" class="btn btn-sm btn-light fw-medium" data-loading data-loading-message="Carregando histórico...">
                        Ver tudo <i class="bi bi-arrow-right ms-1"></i>
                    </a>
                </div>

                @if (imports.Count == 0)
                {
                    <div class="empty-state">
                        <div class="empty-state-icon">
                            <i class="bi bi-inbox"></i>
                        </div>
                        <h6 class="empty-state-title">Nenhuma atividade recente</h6>
                        <p class="empty-state-text">As importacoes realizadas aparecerao aqui com status em tempo real</p>
                        <a asp-controller="Import" asp-action="Index" class="btn btn-sm btn-primary mt-2" data-loading data-loading-message="Carregando importação...">
                            <i class="bi bi-upload me-1"></i> Fazer primeira importacao
                        </a>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Data</th>
                                    <th>Arquivo</th>
                                    <th>Status</th>
                                    <th class="text-end">Linhas</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var import in imports.Take(5))
                                {
                                    var statusClass = import.Status.ToString() switch
                                    {
                                        "Completed" => "success",
                                        "PartiallyCompleted" => "warning",
                                        "Failed" => "danger",
                                        "Processing" => "info",
                                        _ => "secondary"
                                    };
                                    <tr>
                                        <td>@import.ImportedAt.ToString("dd/MM HH:mm")</td>
                                        <td class="text-truncate" style="max-width: 200px;">@import.OriginalFileName</td>
                                        <td><span class="badge bg-@statusClass-subtle text-@statusClass-emphasis">@import.Status</span></td>
                                        <td class="text-end">@import.TotalLines</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@if (string.IsNullOrWhiteSpace(companyDb))
{
    <div class="alert alert-warning mt-3">
        <i class="bi bi-info-circle me-2"></i>
        Nenhuma empresa selecionada. Acesse o menu <strong>Empresas</strong> e selecione uma base para começar.
    </div>
}