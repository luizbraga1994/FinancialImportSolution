@model FinancialImport.Application.Imports.ImportProcessResult
@{
    ViewData["Title"] = "Resultado";
}

<h2>Resultado da importação</h2>

<div class="card">
    <div class="card-body">
        <p><strong>Importadas:</strong> @Model.Imported</p>
        <p><strong>Duplicadas:</strong> @Model.Duplicated</p>
        <p><strong>Inválidas:</strong> @Model.Invalid</p>
        <p><strong>Erros SAP:</strong> @Model.SapErrors</p>
    </div>
</div>
