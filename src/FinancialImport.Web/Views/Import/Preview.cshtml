@using FinancialImport.Domain.Enums
@model FinancialImport.Web.Controllers.ImportPreviewViewModel
@{
    ViewData["Title"] = "Pre-visualizacao da Importacao";
    var totalCredit = Model.Groups.Sum(g => g.TotalCredit);
    var totalDebit = Model.Groups.Sum(g => g.TotalDebit);
    var hasInvalidAccounts = Model.AccountsValidated && Model.InvalidAccountCodes.Count > 0;
    var canConfirm = Model.ValidLines > 0
        && !hasInvalidAccounts
        && Model.Status != ImportStatus.Completed
        && Model.Status != ImportStatus.PartiallyCompleted
        && Model.Status != ImportStatus.Processing
        && Model.Status != ImportStatus.Failed;
    var canReprocess = !hasInvalidAccounts
        && (Model.Status == ImportStatus.Failed
        || Model.Status == ImportStatus.PartiallyCompleted
        || Model.Status == ImportStatus.Cancelled);
    var statusBadgeClass = Model.Status == ImportStatus.Completed ? "bg-success-subtle text-success-emphasis"
        : Model.Status == ImportStatus.PartiallyCompleted ? "bg-warning-subtle text-warning-emphasis"
        : Model.Status == ImportStatus.Failed ? "bg-danger-subtle text-danger-emphasis"
        : Model.Status == ImportStatus.Cancelled ? "bg-secondary-subtle text-secondary-emphasis"
        : Model.Status == ImportStatus.Processing ? "bg-info-subtle text-info-emphasis"
        : "bg-secondary-subtle text-secondary-emphasis";
}

<div class="mb-4 d-flex align-items-center justify-content-between">
    <div>
        <a asp-action="Index" class="btn btn-light btn-sm mb-3">
            <i class="bi bi-arrow-left me-1"></i> Voltar
        </a>
        <h5 class="fw-bold mb-1">Pre-visualizacao da Importacao</h5>
        <p class="text-muted mb-0" style="font-size: 0.85rem;">
            Revise as linhas agrupadas por Observacao e Data antes de enviar ao SAP
        </p>
    </div>
    <span class="badge @statusBadgeClass">@Model.Status</span>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show d-flex align-items-center" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>
        <div>@TempData["Success"]</div>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        <div>@TempData["Error"]</div>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body p-3">
                <div class="text-muted small fw-medium text-uppercase mb-2">Arquivo</div>
                <div class="fw-semibold text-truncate" title="@Model.FileName">
                    <i class="bi bi-file-earmark-text me-2"></i>@Model.FileName
                </div>
                <div class="text-muted small mt-2">
                    Layout: <code>@Model.LayoutDetected</code>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body p-3">
                <div class="text-muted small fw-medium text-uppercase mb-2">Linhas</div>
                <div class="d-flex flex-wrap gap-2">
                    <span class="badge bg-secondary-subtle text-secondary-emphasis">
                        Total: @Model.TotalLines
                    </span>
                    @if (Model.ImportedLines > 0)
                    {
                        <span class="badge bg-primary-subtle text-primary-emphasis">
                            <i class="bi bi-check-circle me-1"></i>Importadas: @Model.ImportedLines
                        </span>
                    }
                    @if (Model.SapErrorLines > 0)
                    {
                        <span class="badge bg-danger-subtle text-danger-emphasis">
                            <i class="bi bi-exclamation-circle me-1"></i>Erro SAP: @Model.SapErrorLines
                        </span>
                    }
                    @if (Model.ValidLines > 0)
                    {
                        <span class="badge bg-success-subtle text-success-emphasis">
                            Pendentes: @Model.ValidLines
                        </span>
                    }
                    @if (Model.InvalidLines > 0)
                    {
                        <span class="badge bg-danger-subtle text-danger-emphasis">
                            Invalidas: @Model.InvalidLines
                        </span>
                    }
                    @if (Model.DuplicatedLines > 0)
                    {
                        <span class="badge bg-warning-subtle text-warning-emphasis">
                            Duplicadas: @Model.DuplicatedLines
                        </span>
                    }
                    @if (Model.ExcludedLines > 0)
                    {
                        <span class="badge bg-secondary-subtle text-secondary-emphasis">
                            Excluidas: @Model.ExcludedLines
                        </span>
                    }
                </div>
                <div class="text-muted small mt-2">
                    Agrupadas em <strong>@Model.Groups.Count</strong> lancamento(s) SAP
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body p-3">
                <div class="text-muted small fw-medium text-uppercase mb-2">Totais</div>
                <div class="d-flex justify-content-between small">
                    <span class="text-muted">Debito</span>
                    <span class="fw-semibold">@totalDebit.ToString("N2")</span>
                </div>
                <div class="d-flex justify-content-between small">
                    <span class="text-muted">Credito</span>
                    <span class="fw-semibold">@totalCredit.ToString("N2")</span>
                </div>
                <div class="d-flex justify-content-between small mt-2 pt-2 border-top">
                    <span class="text-muted">Diferenca</span>
                    <span class="fw-semibold @(totalDebit == totalCredit ? "text-success" : "text-danger")">
                        @((totalDebit - totalCredit).ToString("N2"))
                    </span>
                </div>
            </div>
        </div>
    </div>
</div>

@if (Model.Errors.Count > 0)
{
    <div class="card mb-4 border-danger">
        <div class="card-body p-3">
            <h6 class="fw-bold text-danger mb-2">
                <i class="bi bi-exclamation-triangle me-1"></i>
                Erros de validacao (@Model.Errors.Count)
            </h6>
            <ul class="mb-0 small text-muted">
                @foreach (var error in Model.Errors.Take(20))
                {
                    <li>@error</li>
                }
            </ul>
            @if (Model.Errors.Count > 20)
            {
                <div class="small text-muted mt-2">
                    ... e mais @(Model.Errors.Count - 20) erro(s).
                </div>
            }
        </div>
    </div>
}

@if (Model.InvalidAccountCodes.Count > 0)
{
    <div class="card mb-4 border-danger">
        <div class="card-body p-3">
            <h6 class="fw-bold text-danger mb-2">
                <i class="bi bi-shield-exclamation me-1"></i>
                IMPORTACAO BLOQUEADA — @Model.InvalidAccountCodes.Count conta(s) nao encontrada(s) no SAP
            </h6>
            <p class="small text-danger-emphasis mb-2">
                <strong>A importacao esta bloqueada</strong> porque as contas abaixo nao existem no plano de contas da empresa atual.
                Corrija o arquivo Excel e reimporte, ou cadastre essas contas no SAP antes de confirmar.
                Clique em uma conta para filtrar os grupos que a utilizam.
            </p>
            <div class="d-flex flex-wrap gap-2">
                @foreach (var code in Model.InvalidAccountCodes.Take(50))
                {
                    <button type="button" class="btn btn-sm bg-warning-subtle text-warning-emphasis border border-warning px-2 py-1 rounded small account-filter-chip"
                            data-account="@code"
                            title="Clique para filtrar grupos que usam essa conta">
                        <code class="text-warning-emphasis">@code</code>
                    </button>
                }
            </div>
            @if (Model.InvalidAccountCodes.Count > 50)
            {
                <div class="small text-muted mt-2">
                    ... e mais @(Model.InvalidAccountCodes.Count - 50) conta(s) invalida(s).
                </div>
            }
        </div>
    </div>
}
else if (Model.AccountsValidated)
{
    <div class="alert alert-success d-flex align-items-center py-2 mb-4" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>
        <small>Todas as contas do arquivo foram encontradas no plano de contas do SAP.</small>
    </div>
}
else
{
    <div class="alert alert-info d-flex align-items-center py-2 mb-4" role="alert">
        <i class="bi bi-info-circle-fill me-2"></i>
        <small>Validacao de contas contra o SAP nao executada (sem sessao ativa). Sera validado no momento do envio.</small>
    </div>
}

<div id="accountFilterBar" class="alert alert-primary d-none align-items-center justify-content-between py-2 mb-3" role="alert">
    <div>
        <i class="bi bi-funnel-fill me-2"></i>
        <span>Filtrando grupos pela conta:</span>
        <code id="accountFilterValue" class="bg-white text-primary-emphasis border px-2 py-1 rounded ms-1"></code>
        <span class="text-muted small ms-2" id="accountFilterCount"></span>
    </div>
    <button type="button" class="btn btn-sm btn-outline-primary" id="accountFilterClear">
        <i class="bi bi-x-lg me-1"></i>Limpar filtro
    </button>
</div>

<div class="card mb-4">
    <div class="card-header bg-white d-flex align-items-center justify-content-between">
        <h6 class="fw-bold mb-0">
            <i class="bi bi-collection me-1"></i>
            Lancamentos agrupados por Observacao e Data
        </h6>
        <span class="text-muted small">@Model.Groups.Count grupo(s)</span>
    </div>
    <div class="card-body p-0">
        @if (Model.Groups.Count == 0)
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                Nenhuma linha para pre-visualizar.
            </div>
        }
        else
        {
            <div class="accordion accordion-flush" id="groupsAccordion">
                @for (var i = 0; i < Model.Groups.Count; i++)
                {
                    var group = Model.Groups[i];
                    var collapseId = $"collapse-{i}";
                    var headingId = $"heading-{i}";
                    var groupAccounts = string.Join(" ",
                        group.Lines.SelectMany(l => new[] { l.AccountCode, l.ContraAccountCode })
                            .Where(c => !string.IsNullOrWhiteSpace(c))
                            .Distinct(StringComparer.OrdinalIgnoreCase));
                    <div class="accordion-item group-card @(group.IsExcluded ? "opacity-50" : "")"
                         data-accounts="@groupAccounts">
                        <h2 class="accordion-header d-flex align-items-center" id="@headingId">
                            <button class="accordion-button collapsed flex-grow-1" type="button"
                                    data-bs-toggle="collapse" data-bs-target="#@collapseId"
                                    aria-expanded="false" aria-controls="@collapseId">
                                <div class="d-flex align-items-center justify-content-between w-100 me-3">
                                    <div>
                                        <code class="fw-semibold @(group.IsExcluded ? "text-decoration-line-through text-muted" : "")">@(string.IsNullOrWhiteSpace(group.Reference) ? "(sem referencia)" : group.Reference)</code>
                                        <span class="badge bg-primary-subtle text-primary-emphasis ms-2">@group.PostingDate.ToString("dd/MM/yyyy")</span>
                                        <span class="badge bg-light text-dark border ms-2">@group.LineCount linha(s)</span>
                                        @if (group.IsExcluded)
                                        {
                                            <span class="badge bg-danger-subtle text-danger-emphasis ms-2"><i class="bi bi-slash-circle me-1"></i>Excluido</span>
                                        }
                                        else if (group.IsImported)
                                        {
                                            <span class="badge bg-success-subtle text-success-emphasis ms-2"><i class="bi bi-check-circle me-1"></i>Enviado ao SAP</span>
                                        }
                                    </div>
                                    <div class="small text-muted d-none d-md-block">
                                        D: <strong>@group.TotalDebit.ToString("N2")</strong>
                                        &nbsp;|&nbsp;
                                        C: <strong>@group.TotalCredit.ToString("N2")</strong>
                                    </div>
                                </div>
                            </button>
                            @if (!group.IsExcluded && !group.IsImported && Model.Status != ImportStatus.Processing && Model.Status != ImportStatus.Completed)
                            {
                                <form asp-action="ExcludeGroup" asp-route-id="@Model.ImportFileId" method="post" class="ms-1 me-2">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="groupKeyHash" value="@group.GroupKeyHash" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger"
                                            title="Excluir grupo inteiro (@group.LineCount linha(s))"
                                            onclick="return confirm('Excluir o grupo inteiro? @group.LineCount linha(s) nao serao enviadas ao SAP.');">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            }
                        </h2>
                        <div id="@collapseId" class="accordion-collapse collapse"
                             aria-labelledby="@headingId" data-bs-parent="#groupsAccordion">
                            <div class="accordion-body p-0">
                                @{ var hasEditableLines = group.Lines.Any(l => (l.Status == ImportLineStatus.SapError || l.Status == ImportLineStatus.Invalid) && Model.Status != ImportStatus.Processing && Model.Status != ImportStatus.Completed); }
                                <form asp-action="UpdateAccounts" asp-route-id="@Model.ImportFileId" method="post">
                                @Html.AntiForgeryToken()
                                <div class="table-responsive">
                                    <table class="table table-sm mb-0 small">
                                        <thead class="table-light">
                                            <tr>
                                                <th>Status</th>
                                                <th>Data</th>
                                                <th>Conta</th>
                                                <th>Contrapartida</th>
                                                <th class="text-end">Debito</th>
                                                <th class="text-end">Credito</th>
                                                <th>Historico</th>
                                                <th>Filial</th>
                                                <th>Mensagem</th>
                                                <th class="text-center" style="width: 40px;"></th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @{ var maxLinesPerGroup = 20; var linesShown = 0; }
                                            @foreach (var line in group.Lines.Take(maxLinesPerGroup))
                                            {
                                                var rowBadge = line.Status == ImportLineStatus.Valid ? "bg-success-subtle text-success-emphasis"
                                                    : line.Status == ImportLineStatus.Invalid ? "bg-danger-subtle text-danger-emphasis"
                                                    : line.Status == ImportLineStatus.Duplicated ? "bg-warning-subtle text-warning-emphasis"
                                                    : line.Status == ImportLineStatus.Imported ? "bg-primary-subtle text-primary-emphasis"
                                                    : line.Status == ImportLineStatus.SapError ? "bg-danger-subtle text-danger-emphasis"
                                                    : line.Status == ImportLineStatus.Excluded ? "bg-secondary-subtle text-secondary-emphasis"
                                                    : "bg-secondary-subtle text-secondary-emphasis";
                                                var rowClass = line.Status == ImportLineStatus.Excluded ? "text-muted text-decoration-line-through" : "";
                                                var canExcludeLine = (line.Status == ImportLineStatus.Valid || line.Status == ImportLineStatus.SapError || line.Status == ImportLineStatus.Invalid)
                                                                     && Model.Status != ImportStatus.Processing
                                                                     && Model.Status != ImportStatus.Completed;
                                                var canEditAccount = (line.Status == ImportLineStatus.SapError || line.Status == ImportLineStatus.Invalid)
                                                                     && Model.Status != ImportStatus.Processing
                                                                     && Model.Status != ImportStatus.Completed;
                                                <tr class="@rowClass" data-line-accounts="@line.AccountCode @line.ContraAccountCode">
                                                    <td>
                                                        <span class="badge @rowBadge">@line.Status</span>
                                                    </td>
                                                    <td class="text-nowrap">@line.PostingDate.ToString("dd/MM/yyyy")</td>
                                                    <td>
                                                        @if (canEditAccount)
                                                        {
                                                            <input type="text" name="accountCode[@line.Id]" value="@line.AccountCode"
                                                                   class="form-control form-control-sm font-monospace" style="width: 140px; font-size: 0.75rem;" />
                                                        }
                                                        else
                                                        {
                                                            <code>@line.AccountCode</code>
                                                        }
                                                    </td>
                                                    <td>
                                                        @if (canEditAccount)
                                                        {
                                                            <input type="text" name="contraAccountCode[@line.Id]" value="@line.ContraAccountCode"
                                                                   class="form-control form-control-sm font-monospace" style="width: 140px; font-size: 0.75rem;" />
                                                        }
                                                        else
                                                        {
                                                            <code>@line.ContraAccountCode</code>
                                                        }
                                                    </td>
                                                    <td class="text-end">@((line.DebitAmount ?? 0m).ToString("N2"))</td>
                                                    <td class="text-end">@((line.CreditAmount ?? 0m).ToString("N2"))</td>
                                                    <td class="text-truncate" style="max-width: 240px;" title="@line.LineMemo">@line.LineMemo</td>
                                                    <td>@(line.BranchCode ?? "-")</td>
                                                    <td class="small text-muted">
                                                        @if (!string.IsNullOrWhiteSpace(line.ValidationMessage))
                                                        {
                                                            <span class="@(line.Status == ImportLineStatus.Excluded ? "text-muted" : "text-danger")">@line.ValidationMessage</span>
                                                        }
                                                        else if (!string.IsNullOrWhiteSpace(line.SapReturnMessage))
                                                        {
                                                            <span>@line.SapReturnMessage</span>
                                                        }
                                                        else
                                                        {
                                                            <span>-</span>
                                                        }
                                                    </td>
                                                    <td class="text-center">
                                                        @if (canExcludeLine)
                                                        {
                                                            <button type="button" class="btn btn-sm btn-link text-danger p-0"
                                                                    title="Excluir esta linha"
                                                                    onclick="excludeLine(@line.Id, @Model.ImportFileId)">
                                                                <i class="bi bi-x-circle"></i>
                                                            </button>
                                                        }
                                                    </td>
                                                </tr>
                                            }
                                            @if (group.LineCount > maxLinesPerGroup)
                                            {
                                                <tr class="table-warning">
                                                    <td colspan="10" class="text-center small text-muted py-2">
                                                        <i class="bi bi-three-dots me-1"></i>
                                                        @(group.LineCount - maxLinesPerGroup) linha(s) omitida(s) para performance.
                                                        Total do grupo: @group.LineCount linha(s).
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                                @if (hasEditableLines)
                                {
                                    <div class="p-2 bg-light border-top text-end">
                                        <button type="submit" class="btn btn-sm btn-warning">
                                            <i class="bi bi-pencil-square me-1"></i>Salvar contas alteradas
                                        </button>
                                    </div>
                                }
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<div class="d-flex justify-content-end gap-2">
    <a asp-action="Index" class="btn btn-light">
        <i class="bi bi-x-lg me-1"></i> Cancelar
    </a>
    @if (canReprocess)
    {
        <form asp-action="Reprocess" asp-route-id="@Model.ImportFileId" method="post" class="d-inline"
              data-loading data-loading-message="Reprocessando ao SAP..."
              data-cancel-url="/Import/Cancel/@Model.ImportFileId"
              data-progress-url="/Import/Progress/@Model.ImportFileId">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-warning px-4"
                    onclick="return confirm('Reprocessar linhas com erro? O sistema vai tentar reenviar ao SAP apenas os lancamentos que falharam.');">
                <i class="bi bi-arrow-clockwise me-1"></i> Reprocessar
            </button>
        </form>
    }
    @if (canConfirm)
    {
        <form asp-action="Confirm" asp-route-id="@Model.ImportFileId" method="post" class="d-inline"
              data-loading data-loading-message="Enviando ao SAP..."
              data-cancel-url="/Import/Cancel/@Model.ImportFileId"
              data-progress-url="/Import/Progress/@Model.ImportFileId">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-primary px-4"
                    onclick="return confirm('Confirmar envio de @Model.ValidLines linha(s) ao SAP em @Model.Groups.Count lancamento(s)?');">
                <i class="bi bi-send-check me-1"></i> Confirmar Importacao
            </button>
        </form>
    }
    else if (hasInvalidAccounts)
    {
        <button type="button" class="btn btn-danger px-4" disabled
                title="Importacao bloqueada — existem contas nao encontradas no plano de contas do SAP.">
            <i class="bi bi-shield-exclamation me-1"></i> Bloqueado
        </button>
    }
    else if (Model.ValidLines == 0 && Model.DuplicatedLines > 0
             && Model.Status != ImportStatus.Completed
             && Model.Status != ImportStatus.PartiallyCompleted
             && Model.Status != ImportStatus.Processing)
    {
        <form asp-action="ForceReimport" asp-route-id="@Model.ImportFileId" method="post" class="d-inline">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-warning px-4"
                    onclick="return confirm('Atencao: @Model.DuplicatedLines linha(s) ja foram enviadas ao SAP anteriormente. Reimporta-las pode gerar lancamentos duplicados no SAP. Deseja continuar?');">
                <i class="bi bi-arrow-repeat me-1"></i> Reimportar Duplicadas (@Model.DuplicatedLines)
            </button>
        </form>
    }
    else if (!canReprocess)
    {
        <button type="button" class="btn btn-primary px-4" disabled
                title="Nao ha linhas validas para confirmar ou ja foi processado.">
            <i class="bi bi-send-check me-1"></i> Confirmar Importacao
        </button>
    }
</div>

@section Scripts {
    <script>
        // Client-side filter: clicking a "conta nao encontrada" badge shows
        // ONLY the groups that reference that account (either ContaContabil
        // or Contrapartida). A filter bar at the top lets the user clear it.
        (function () {
            var chips = document.querySelectorAll('.account-filter-chip');
            var bar = document.getElementById('accountFilterBar');
            var valueLabel = document.getElementById('accountFilterValue');
            var countLabel = document.getElementById('accountFilterCount');
            var clearBtn = document.getElementById('accountFilterClear');
            var cards = document.querySelectorAll('.group-card');

            function applyFilter(account) {
                var rows = document.querySelectorAll('tr[data-line-accounts]');
                if (!account) {
                    cards.forEach(function (c) { c.style.display = ''; });
                    rows.forEach(function (r) { r.style.opacity = ''; r.style.backgroundColor = ''; });
                    bar.classList.add('d-none');
                    bar.classList.remove('d-flex');
                    chips.forEach(function (c) { c.classList.remove('active', 'btn-warning'); });
                    return;
                }

                var visible = 0;
                var needle = account.toLowerCase();
                cards.forEach(function (c) {
                    var accounts = (c.getAttribute('data-accounts') || '').toLowerCase().split(/\s+/);
                    if (accounts.indexOf(needle) !== -1) {
                        c.style.display = '';
                        visible++;
                    } else {
                        c.style.display = 'none';
                    }
                });

                rows.forEach(function (r) {
                    var lineAccounts = (r.getAttribute('data-line-accounts') || '').toLowerCase().split(/\s+/);
                    if (lineAccounts.indexOf(needle) !== -1) {
                        r.style.opacity = '';
                        r.style.backgroundColor = 'rgba(255, 193, 7, 0.15)';
                    } else {
                        r.style.opacity = '0.4';
                        r.style.backgroundColor = '';
                    }
                });

                valueLabel.textContent = account;
                countLabel.textContent = '(' + visible + ' grupo' + (visible === 1 ? '' : 's') + ' exibido' + (visible === 1 ? '' : 's') + ')';
                bar.classList.remove('d-none');
                bar.classList.add('d-flex');
                chips.forEach(function (c) {
                    if (c.getAttribute('data-account') === account) {
                        c.classList.add('active', 'btn-warning');
                    } else {
                        c.classList.remove('active', 'btn-warning');
                    }
                });
                bar.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }

            chips.forEach(function (chip) {
                chip.addEventListener('click', function () {
                    applyFilter(chip.getAttribute('data-account'));
                });
            });

            if (clearBtn) clearBtn.addEventListener('click', function () { applyFilter(null); });
        })();

        function excludeLine(lineId, importFileId) {
            if (!confirm('Excluir apenas esta linha? Se o grupo ficar desbalanceado (D != C), o SAP pode rejeitar o lancamento inteiro.')) return;
            var form = document.createElement('form');
            form.method = 'POST';
            form.action = '/Import/ExcludeLine/' + importFileId;
            var token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            var t = document.createElement('input'); t.type = 'hidden'; t.name = '__RequestVerificationToken'; t.value = token;
            form.appendChild(t);
            var l = document.createElement('input'); l.type = 'hidden'; l.name = 'lineId'; l.value = lineId;
            form.appendChild(l);
            document.body.appendChild(form);
            form.submit();
        }
    </script>
}