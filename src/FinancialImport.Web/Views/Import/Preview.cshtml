@model FinancialImport.Web.Models.PreviewViewModel
@{
    ViewData["Title"] = "Prévia";
}

<h2>Prévia da importação</h2>

<div class="card mb-3">
    <div class="card-body">
        <p><strong>Layout:</strong> @Model.LayoutDetected</p>
        <p><strong>Total de linhas:</strong> @Model.TotalLines</p>
        <p><strong>Linhas inválidas:</strong> @Model.InvalidLines</p>
    </div>
</div>

@if (Model.Errors.Count > 0)
{
    <div class="alert alert-warning">
        <ul>
            @foreach (var error in Model.Errors)
            {
                <li>@error</li>
            }
        </ul>
    </div>
}

<form asp-action="Confirm" method="post">
    <input type="hidden" name="importFileId" value="@Model.ImportFileId" />
    <button type="submit" class="btn btn-success">Confirmar importação</button>
</form>
