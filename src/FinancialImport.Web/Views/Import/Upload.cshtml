@model FinancialImport.Web.Models.UploadViewModel
@{
    ViewData["Title"] = "Upload";
}

<h2>Upload de planilha</h2>

<form asp-action="Upload" method="post" enctype="multipart/form-data">
    <div class="mb-3">
        <label asp-for="File" class="form-label">Arquivo</label>
        <input asp-for="File" type="file" class="form-control" />
        <span asp-validation-for="File" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Layout" class="form-label">Layout (opcional)</label>
        <input asp-for="Layout" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="BranchDefault" class="form-label">Filial padrão</label>
        <input asp-for="BranchDefault" class="form-control" />
    </div>
    <div class="form-check mb-3">
        <input asp-for="UseBranchFromFile" class="form-check-input" />
        <label asp-for="UseBranchFromFile" class="form-check-label">Usar filial do arquivo</label>
    </div>
    <button type="submit" class="btn btn-primary">Pré-visualizar</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
