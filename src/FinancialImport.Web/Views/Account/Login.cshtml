@model FinancialImport.Web.Controllers.LoginViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - Financial Import</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YcnS/1t9/fONBXnaKArTmis6ROHPiQERxKwB"
          crossorigin="anonymous" />
    <style>
        html, body {
            height: 100%;
        }
        body {
            display: flex;
            align-items: center;
            justify-content: center;
            background-color: #f5f5f5;
        }
    </style>
</head>
<body>
    <div class="w-100" style="max-width: 420px; padding: 1rem;">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <div class="text-center mb-4">
                    <div class="bg-dark text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3"
                         style="width: 64px; height: 64px;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6m2-3a2 2 0 1 1-4 0 2 2 0 0 1 4 0m4 8c0 1-1 1-1 1H3s-1 0-1-1 1-4 6-4 6 3 6 4m-1-.004c-.001-.246-.154-.986-.832-1.664C11.516 10.68 10.289 10 8 10s-3.516.68-4.168 1.332c-.678.678-.83 1.418-.832 1.664z"/>
                        </svg>
                    </div>
                    <h4 class="fw-bold">Financial Import</h4>
                    <p class="text-muted small">Entre com suas credenciais para acessar o sistema</p>
                </div>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger py-2" role="alert">
                        @ViewBag.Error
                    </div>
                }

                <div asp-validation-summary="All" class="text-danger small mb-3"></div>

                <form asp-controller="Account" asp-action="Login" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="ReturnUrl" value="@ViewData["ReturnUrl"]" />

                    <div class="mb-3">
                        <label for="Login" class="form-label">Login</label>
                        <input type="text"
                               class="form-control"
                               id="Login"
                               name="Login"
                               value="@Model?.Login"
                               placeholder="Seu usuário"
                               required
                               autofocus />
                    </div>

                    <div class="mb-4">
                        <label for="Password" class="form-label">Senha</label>
                        <input type="password"
                               class="form-control"
                               id="Password"
                               name="Password"
                               placeholder="Sua senha"
                               required />
                    </div>

                    <button type="submit" class="btn btn-dark w-100 py-2">
                        Entrar
                    </button>
                </form>
            </div>
        </div>
        <p class="text-center text-muted small mt-3">&copy; @DateTime.Now.Year Financial Import</p>
    </div>
</body>
</html>
