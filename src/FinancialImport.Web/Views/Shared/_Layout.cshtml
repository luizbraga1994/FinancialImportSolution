@inject FinancialImport.Application.Settings.ISystemSettingsService AppSettings
<!DOCTYPE html>
<html lang="pt-BR" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @(AppSettings.Get("Aparencia:AppName") ?? "Financial Import")</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet" asp-append-version="true" />
    @{
        var corSidebar = AppSettings.Get("Aparencia:CorSidebar");
        var corSidebarHover = AppSettings.Get("Aparencia:CorSidebarHover");
        var corPrimaria = AppSettings.Get("Aparencia:CorPrimaria");
        var corFundo = AppSettings.Get("Aparencia:CorFundo");
        var corTextoSidebar = AppSettings.Get("Aparencia:CorTextoSidebar");
        var hasCustomColors = !string.IsNullOrWhiteSpace(corSidebar) || !string.IsNullOrWhiteSpace(corPrimaria)
                           || !string.IsNullOrWhiteSpace(corFundo) || !string.IsNullOrWhiteSpace(corTextoSidebar);
    }
    @if (hasCustomColors)
    {
        <style>
            :root {
                @if (!string.IsNullOrWhiteSpace(corSidebar)) { @Html.Raw($"--sidebar-bg: {corSidebar};") }
                @if (!string.IsNullOrWhiteSpace(corSidebarHover)) { @Html.Raw($"--sidebar-hover: {corSidebarHover};") }
                @if (!string.IsNullOrWhiteSpace(corPrimaria)) { @Html.Raw($"--sidebar-active: {corPrimaria};") }
                @if (!string.IsNullOrWhiteSpace(corFundo)) { @Html.Raw($"--body-bg: {corFundo};") }
                @if (!string.IsNullOrWhiteSpace(corTextoSidebar)) { @Html.Raw($"--sidebar-text: {corTextoSidebar};") }
            }
            @if (!string.IsNullOrWhiteSpace(corPrimaria))
            {
                @Html.Raw($@"
                .btn-primary {{ background-color: {corPrimaria}; border-color: {corPrimaria}; }}
                .btn-primary:hover {{ background-color: {corPrimaria}; border-color: {corPrimaria}; filter: brightness(0.9); }}
                .sidebar-link.active {{ color: {corPrimaria}; border-left-color: {corPrimaria}; background: rgba(59,130,246,0.1); }}
                a {{ color: {corPrimaria}; }}
                ")
            }
        </style>
    }
</head>
<body>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <!-- SIDEBAR -->
        <aside class="sidebar d-flex flex-column" id="sidebar">
            <div class="sidebar-brand">
                @{
                    var sidebarLogo = AppSettings.Get("Aparencia:LogoUrl");
                    var sidebarAppName = AppSettings.Get("Aparencia:AppName") ?? "Financial Import";
                }
                @if (!string.IsNullOrWhiteSpace(sidebarLogo))
                {
                    <img src="@sidebarLogo" alt="@sidebarAppName" style="height: 28px; width: auto;" class="me-2" />
                }
                else
                {
                    <i class="bi bi-stack me-2"></i>
                }
                <span>@sidebarAppName</span>
            </div>

            <nav class="sidebar-nav flex-grow-1">
                <a href="@Url.Action("Index", "Home")" class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")">
                    <i class="bi bi-grid-1x2-fill"></i><span>Dashboard</span>
                </a>
                <a href="@Url.Action("Index", "Import")" class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Import" ? "active" : "")" data-loading data-loading-message="Carregando importação...">
                    <i class="bi bi-upload"></i><span>Importar</span>
                </a>
                <a href="@Url.Action("Index", "History")" class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "History" ? "active" : "")" data-loading data-loading-message="Carregando histórico...">
                    <i class="bi bi-clock-history"></i><span>Historico</span>
                </a>
                <a href="@Url.Action("Index", "Company")" class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Company" ? "active" : "")" data-loading data-loading-message="Carregando empresas...">
                    <i class="bi bi-building"></i><span>Empresas</span>
                </a>

                <div class="sidebar-divider"></div>
                <div class="sidebar-section-title">Sistema</div>

                @if (User.HasClaim("global_admin", "True") || User.HasClaim("global_admin", "true"))
                {
                    <a href="@Url.Action("Index", "User")" class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "User" ? "active" : "")" data-loading data-loading-message="Carregando usuários...">
                        <i class="bi bi-people"></i><span>Usuarios</span>
                    </a>
                    <a href="@Url.Action("Index", "Profile")" class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Profile" ? "active" : "")" data-loading data-loading-message="Carregando perfis...">
                        <i class="bi bi-shield-lock"></i><span>Perfis</span>
                    </a>
                    <a href="@Url.Action("Index", "Settings")" class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Settings" ? "active" : "")" data-loading data-loading-message="Carregando configuracoes...">
                        <i class="bi bi-gear-fill"></i><span>Configuracoes</span>
                    </a>
                    <a href="@Url.Action("Index", "Log")" class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Log" ? "active" : "")" data-loading data-loading-message="Carregando logs...">
                        <i class="bi bi-journal-text"></i><span>Logs</span>
                    </a>
                }
            </nav>

            <div class="sidebar-footer">
                <div class="d-flex align-items-center">
                    <div class="sidebar-avatar">
                        <i class="bi bi-person-fill"></i>
                    </div>
                    <div class="flex-grow-1 ms-2 overflow-hidden">
                        <div class="sidebar-user-name">@(User.FindFirst("name")?.Value ?? User.Identity?.Name ?? "Usuario")</div>
                        <div class="sidebar-user-role">@(User.HasClaim("global_admin", "true") ? "Administrador" : "Operador")</div>
                    </div>
                    <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline" data-loading data-loading-message="Saindo...">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-link sidebar-logout-btn p-0" title="Sair">
                            <i class="bi bi-box-arrow-right"></i>
                        </button>
                    </form>
                </div>
            </div>
        </aside>

        <!-- MAIN CONTENT -->
        <div class="main-wrapper">
            <!-- TOP BAR -->
            <header class="topbar">
                <button class="btn btn-link topbar-toggle d-lg-none" type="button" onclick="document.getElementById('sidebar').classList.toggle('show')">
                    <i class="bi bi-list fs-4"></i>
                </button>
                <h1 class="topbar-title">@ViewData["Title"]</h1>
                <div class="topbar-actions">
                    @{
                        var companyDb = User.FindFirst("company_db")?.Value;
                        var companyName = User.FindFirst("company_name")?.Value;
                    }
                    @if (!string.IsNullOrWhiteSpace(companyDb))
                    {
                        <span class="badge bg-primary-subtle text-primary-emphasis px-3 py-2" style="font-size: 0.8rem;">
                            <i class="bi bi-database me-1"></i>@(companyName ?? companyDb)
                        </span>
                    }
                </div>
            </header>

            <!-- PAGE CONTENT -->
            <main class="main-content">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show d-flex align-items-center" role="alert">
                        <i class="bi bi-check-circle-fill me-2"></i>
                        <div>@TempData["Success"]</div>
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        <div>@TempData["Error"]</div>
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                @RenderBody()
            </main>

            <footer class="main-footer">
                &copy; @DateTime.Now.Year Financial Import &mdash; Integracao Contabil SAP Business One
            </footer>
        </div>

        <!-- SIDEBAR OVERLAY (mobile) -->
        <div class="sidebar-overlay d-lg-none" onclick="document.getElementById('sidebar').classList.remove('show')"></div>
    }
    else
    {
        @RenderBody()
    }

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>