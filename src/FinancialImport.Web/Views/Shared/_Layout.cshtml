<!DOCTYPE html>
<html lang="pt-BR" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Financial Import</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YcnS/1t9/fONBXnaKArTmis6ROHPiQERxKwB" crossorigin="anonymous" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet" />
</head>
<body>
@if (User.Identity?.IsAuthenticated == true)
{
    <!-- SIDEBAR -->
    <aside class="sidebar d-flex flex-column" id="sidebar">
        <div class="sidebar-brand">
            <i class="bi bi-stack me-2"></i>
            <span>Financial Import</span>
        </div>

        <nav class="sidebar-nav flex-grow-1">
            <a href="@Url.Action("Index","Home")" class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")">
                <i class="bi bi-grid-1x2-fill"></i><span>Dashboard</span>
            </a>
            <a href="@Url.Action("Index","Import")" class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Import" ? "active" : "")">
                <i class="bi bi-upload"></i><span>Importar</span>
            </a>
            <a href="@Url.Action("Index","History")" class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "History" ? "active" : "")">
                <i class="bi bi-clock-history"></i><span>Historico</span>
            </a>
            <a href="@Url.Action("Index","Company")" class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Company" ? "active" : "")">
                <i class="bi bi-building"></i><span>Empresas</span>
            </a>

            <div class="sidebar-divider"></div>
            <div class="sidebar-section-title">Sistema</div>

            <a href="#" class="sidebar-link disabled">
                <i class="bi bi-people"></i><span>Usuarios</span>
            </a>
            <a href="#" class="sidebar-link disabled">
                <i class="bi bi-shield-lock"></i><span>Perfis</span>
            </a>
            <a href="#" class="sidebar-link disabled">
                <i class="bi bi-journal-text"></i><span>Logs</span>
            </a>
        </nav>

        <div class="sidebar-footer">
            <div class="d-flex align-items-center">
                <div class="sidebar-avatar">
                    <i class="bi bi-person-fill"></i>
                </div>
                <div class="flex-grow-1 ms-2 overflow-hidden">
                    <div class="sidebar-user-name">@(User.FindFirst("name")?.Value ?? User.Identity?.Name ?? "Usuario")</div>
                    <div class="sidebar-user-role">@(User.HasClaim("global_admin","true") ? "Administrador" : "Operador")</div>
                </div>
                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-link sidebar-logout-btn p-0" title="Sair">
                        <i class="bi bi-box-arrow-right"></i>
                    </button>
                </form>
            </div>
        </div>
    </aside>

    <!-- MAIN CONTENT -->
    <div class="main-wrapper">
        <!-- TOP BAR -->
        <header class="topbar">
            <button class="btn btn-link topbar-toggle d-lg-none" type="button" onclick="document.getElementById('sidebar').classList.toggle('show')">
                <i class="bi bi-list fs-4"></i>
            </button>
            <h1 class="topbar-title">@ViewData["Title"]</h1>
            <div class="topbar-actions">
                @if (ViewData["CompanyName"] != null)
                {
                    <span class="badge bg-primary-subtle text-primary-emphasis me-2">
                        <i class="bi bi-building me-1"></i>@ViewData["CompanyName"]
                    </span>
                }
            </div>
        </header>

        <!-- PAGE CONTENT -->
        <main class="main-content">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show d-flex align-items-center" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i>
                    <div>@TempData["Success"]</div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    <div>@TempData["Error"]</div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @RenderBody()
        </main>

        <footer class="main-footer">
            &copy; @DateTime.Now.Year Financial Import &mdash; Integracao Contabil SAP Business One
        </footer>
    </div>

    <!-- SIDEBAR OVERLAY (mobile) -->
    <div class="sidebar-overlay d-lg-none" onclick="document.getElementById('sidebar').classList.remove('show')"></div>
}
else
{
    @RenderBody()
}

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
            crossorigin="anonymous"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
